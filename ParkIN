<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>ANPR Firebase Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
      text-align: center;
    }

    h1 {
      margin-top: 20px;
      color: #22c55e;
    }

    .container {
      margin-top: 40px;
    }

    .card {
      background: #1e293b;
      padding: 25px;
      margin: auto;
      width: 320px;
      border-radius: 15px;
      box-shadow: 0 0 25px rgba(0,0,0,0.4);
    }

    #plate {
      font-size: 42px;
      margin-top: 15px;
      color: #38bdf8;
      letter-spacing: 2px;
    }

    #time {
      margin-top: 10px;
      font-size: 14px;
      color: #facc15;
    }

    #status {
      margin-top: 10px;
      font-size: 14px;
      color: #22c55e;
    }

    button {
      margin-top: 20px;
      padding: 10px 18px;
      border: none;
      border-radius: 10px;
      background: #22c55e;
      color: white;
      cursor: pointer;
      font-size: 14px;
    }

    button:hover {
      background: #16a34a;
    }
  </style>
</head>

<body>

<h1>🚗 ANPR Live Dashboard</h1>

<div class="container">
  <div class="card">
    <h2>Detected Plate</h2>
    <div id="plate">Waiting...</div>
    <div id="time">--</div>
    <div id="status">Connecting to Firebase...</div>
    <button onclick="manualRefresh()">Refresh</button>
  </div>
</div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
  import { getDatabase, ref, onValue } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

  // 🔴 REPLACE THIS CONFIG
  const firebaseConfig = {
    apiKey: "YOUR_API_KEY",
    authDomain: "YOUR_PROJECT.firebaseapp.com",
    databaseURL: "https://YOUR_PROJECT.firebaseio.com",
    projectId: "YOUR_PROJECT",
  };

  const app = initializeApp(firebaseConfig);
  const db = getDatabase(app);

  const plateRef = ref(db, "anpr");

  function updateUI(data) {
    if (!data) {
      document.getElementById("plate").innerText = "No Data";
      document.getElementById("status").innerText = "No record found";
      return;
    }

    document.getElementById("plate").innerText = data.plate || "Unknown";
    document.getElementById("time").innerText = data.time || "--";

    if (data.plate && data.plate !== "No Plate Found") {
      document.getElementById("status").innerText = "Vehicle Detected ✅";
    } else {
      document.getElementById("status").innerText = "No Vehicle ❌";
    }
  }

  // 🔄 Real-time listener
  onValue(plateRef, (snapshot) => {
    const data = snapshot.val();
    updateUI(data);
  });

  // 🔁 Manual refresh
  function manualRefresh() {
    onValue(plateRef, (snapshot) => {
      const data = snapshot.val();
      updateUI(data);
    });
  }

  window.manualRefresh = manualRefresh;
</script>

</body>
</html>
